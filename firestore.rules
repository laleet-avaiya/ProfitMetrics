rules_version = '2';

// TEMPORARY — permissive rules for development / unblock.
// Any signed-in user can read and write all Firestore data.
// Tighten before production (role-based rules).

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
