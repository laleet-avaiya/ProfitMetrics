rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isCompanyOwner(companyId) {
      return isAuthenticated() && request.auth.uid == companyId;
    }

    function ownsDocument() {
      return isAuthenticated() && resource.data.companyId == request.auth.uid;
    }

    function createsForOwnCompany() {
      return isAuthenticated() && request.resource.data.companyId == request.auth.uid;
    }

    match /companies/{companyId} {
      allow read, update, delete: if isCompanyOwner(companyId);
      allow create: if isAuthenticated() && request.resource.data.companyId == request.auth.uid;
    }

    match /products/{docId} {
      allow read, update, delete: if ownsDocument();
      allow create: if createsForOwnCompany();
    }

    match /sales/{docId} {
      allow read, update, delete: if ownsDocument();
      allow create: if createsForOwnCompany();
    }

    match /expenses/{docId} {
      allow read, update, delete: if ownsDocument();
      allow create: if createsForOwnCompany();
    }

    match /vendors/{docId} {
      allow read, update, delete: if ownsDocument();
      allow create: if createsForOwnCompany();
    }

    match /auditLogs/{logId} {
      allow create: if isAuthenticated()
        && request.resource.data.companyId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.companyId == request.auth.uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
