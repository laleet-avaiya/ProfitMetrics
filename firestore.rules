rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email.lower();
    }

    function orgMemberPath(orgId) {
      return /databases/$(database)/documents/orgMembers/$(orgId + '_' + request.auth.uid);
    }

    function isOrgMember(orgId) {
      return isAuthenticated()
        && exists(orgMemberPath(orgId))
        && get(orgMemberPath(orgId)).data.status == 'active';
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && get(orgMemberPath(orgId)).data.role == 'admin';
    }

    function memberDocPath(companyId) {
      return /databases/$(database)/documents/companyMembers/$(companyId + '_' + request.auth.uid);
    }

    function memberExists(companyId) {
      return isAuthenticated() && exists(memberDocPath(companyId));
    }

    function getMember(companyId) {
      return get(memberDocPath(companyId)).data;
    }

    function isActiveMember(companyId) {
      return memberExists(companyId) && getMember(companyId).status == 'active';
    }

    function memberRole(companyId) {
      return getMember(companyId).role;
    }

    function isCompanyAdmin(companyId) {
      return isActiveMember(companyId) && memberRole(companyId) == 'admin';
    }

    function rolePermissionsPath(companyId, role) {
      return /databases/$(database)/documents/companyRoles/$(companyId + '_' + role);
    }

    function isBusinessDataModule(module) {
      return module == 'customers'
        || module == 'sales'
        || module == 'invoices'
        || module == 'payments'
        || module == 'purchases'
        || module == 'expenses'
        || module == 'vendors'
        || module == 'products';
    }

    function managerBuiltinPermission(module, action) {
      return (module == 'dashboard' && action == 'view')
        || (module == 'reports' && action == 'view')
        || (module == 'ai_assistant' && (action == 'view' || action == 'create'))
        || (module == 'settings' && (action == 'view' || action == 'update'))
        || (module == 'subscription' && action == 'view')
        || (isBusinessDataModule(module)
          && (action == 'view' || action == 'create' || action == 'update' || action == 'delete'));
    }

    function viewerBuiltinPermission(module, action) {
      return (module == 'dashboard' && action == 'view')
        || (module == 'reports' && action == 'view')
        || (module == 'ai_assistant' && (action == 'view' || action == 'create'))
        || (module == 'settings' && action == 'view')
        || (module == 'subscription' && action == 'view')
        || (isBusinessDataModule(module) && action == 'view');
    }

    function builtinRolePermission(role, module, action) {
      return (role == 'manager' && managerBuiltinPermission(module, action))
        || (role == 'viewer' && viewerBuiltinPermission(module, action))
        || (role == 'accountant' && module == 'reports' && action == 'view');
    }

    function storedRolePermission(companyId, module, action) {
      let rolePath = rolePermissionsPath(companyId, memberRole(companyId));
      let key = module + '.' + action;
      return exists(rolePath)
        && 'permissions' in get(rolePath).data
        && get(rolePath).data.permissions is map
        && key in get(rolePath).data.permissions
        ? get(rolePath).data.permissions[key]
        : null;
    }

    function hasModulePermission(companyId, module, action) {
      let role = memberRole(companyId);
      let stored = storedRolePermission(companyId, module, action);
      return isActiveMember(companyId)
        && (
          role == 'admin'
          || stored == true
          || (stored != false && builtinRolePermission(role, module, action))
        );
    }

    function companyOrgId(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)).data.orgId;
    }

    function canManageCompanyRoles(companyId) {
      return isCompanyAdmin(companyId) || isOrgAdmin(companyOrgId(companyId));
    }

    function isReportDataModule(module) {
      return module == 'products'
        || module == 'sales'
        || module == 'expenses'
        || module == 'vendors'
        || module == 'purchases'
        || module == 'customers'
        || module == 'invoices'
        || module == 'payments';
    }

    function canReadCompanyModule(companyId, module) {
      return hasModulePermission(companyId, module, 'view')
        || (memberRole(companyId) == 'accountant' && isReportDataModule(module));
    }

    function canReadModuleDoc(module) {
      return isAuthenticated()
        && (resource == null || canReadCompanyModule(resource.data.companyId, module));
    }

    function createdByUnchanged() {
      return !('createdBy' in resource.data)
        || request.resource.data.createdBy == resource.data.createdBy;
    }

    function canCreateModule(module) {
      let companyId = request.resource.data.companyId;
      return isActiveMember(companyId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && (isCompanyAdmin(companyId) || hasModulePermission(companyId, module, 'create'));
    }

    function canUpdateModuleDoc(module) {
      return ownsDocument()
        && maintainsCompanyId()
        && createdByUnchanged()
        && deletedFieldChangeAllowed(module)
        && (
          (
            (isCompanyAdmin(resource.data.companyId) || hasModulePermission(resource.data.companyId, module, 'update'))
            && request.resource.data.deleted != true
            && request.resource.data.updatedBy == request.auth.uid
          )
          || isSoftDeleteUpdate(module)
        );
    }

    function isSoftDeleting() {
      return resource.data.deleted != true && request.resource.data.deleted == true;
    }

    function isSoftDeleteUpdate(module) {
      return isSoftDeleting()
        && request.resource.data.deletedBy == request.auth.uid
        && hasModulePermission(resource.data.companyId, module, 'delete');
    }

    function deletedFieldChangeAllowed(module) {
      return request.resource.data.deleted == resource.data.deleted
        || (resource.data.deleted != true && isSoftDeleteUpdate(module));
    }

    function canDeleteModuleDoc(module) {
      return false;
    }

    function maintainsCompanyId() {
      return request.resource.data.companyId == resource.data.companyId;
    }

    function ownsDocument() {
      return isAuthenticated() && isActiveMember(resource.data.companyId);
    }

    function orgProtectedFieldsUnchanged() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny([
        'subscriptionStart',
        'subscriptionEnd',
        'companyQuota',
        'aiMessagesUsed',
        'aiMessageQuota',
      ]);
    }

    function companyOrgIdUnchanged() {
      return request.resource.data.orgId == resource.data.orgId;
    }

    function companyCreatedByUnchanged() {
      return request.resource.data.createdBy == resource.data.createdBy;
    }

    function orgOwnerUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId;
    }

    function isBootstrapOrgMember(memberId) {
      let data = request.resource.data;
      return isAuthenticated()
        && data.userId == request.auth.uid
        && data.role == 'admin'
        && data.status == 'active'
        && memberId == data.orgId + '_' + request.auth.uid
        && get(/databases/$(database)/documents/orgs/$(data.orgId)).data.ownerId == request.auth.uid;
    }

    function isOrgMemberJoinViaCompany(memberId) {
      let data = request.resource.data;
      return isAuthenticated()
        && data.userId == request.auth.uid
        && data.role == 'member'
        && data.status == 'active'
        && memberId == data.orgId + '_' + request.auth.uid
        && data.bootstrapCompanyId != null
        && exists(/databases/$(database)/documents/companyMembers/$(data.bootstrapCompanyId + '_' + request.auth.uid))
        && get(/databases/$(database)/documents/companies/$(data.bootstrapCompanyId)).data.orgId == data.orgId;
    }

    function isBootstrapAdminMember(memberId) {
      let data = request.resource.data;
      return isAuthenticated()
        && data.userId == request.auth.uid
        && data.role == 'admin'
        && data.status == 'active'
        && memberId == data.companyId + '_' + request.auth.uid
        && get(/databases/$(database)/documents/companies/$(data.companyId)).data.createdBy == request.auth.uid;
    }

    function ownsParentAiChat(chatDocId) {
      return isAuthenticated()
        && hasModulePermission(
          get(/databases/$(database)/documents/aiChats/$(chatDocId)).data.companyId,
          'ai_assistant',
          'view'
        );
    }

    function inviteEmailMatchesAuth() {
      return isAuthenticated()
        && request.auth.token.email != null
        && resource.data.email == authEmail();
    }

    function isSelfJoinViaInvite(memberId) {
      let data = request.resource.data;
      return isAuthenticated()
        && data.userId == request.auth.uid
        && data.status == 'active'
        && data.inviteId != null
        && memberId == data.companyId + '_' + request.auth.uid
        && get(/databases/$(database)/documents/companyInvites/$(data.inviteId)).data.status == 'pending'
        && get(/databases/$(database)/documents/companyInvites/$(data.inviteId)).data.email == authEmail()
        && get(/databases/$(database)/documents/companyInvites/$(data.inviteId)).data.companyId == data.companyId
        && get(/databases/$(database)/documents/companyInvites/$(data.inviteId)).data.role == data.role;
    }

    function isAcceptingInvite() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return inviteEmailMatchesAuth()
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && changed.hasOnly(['status', 'updatedAt']);
    }

    match /users/{userId} {
      allow read, create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /orgs/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.id == orgId;
      allow update: if isOrgAdmin(orgId)
        && orgOwnerUnchanged()
        && createdByUnchanged()
        && orgProtectedFieldsUnchanged()
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if false;
    }

    match /orgMembers/{memberId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isOrgMember(resource.data.orgId)
      );
      allow create: if isBootstrapOrgMember(memberId) || isOrgMemberJoinViaCompany(memberId);
      allow update: if isOrgAdmin(resource.data.orgId)
        && resource.data.userId != request.auth.uid
        && request.resource.data.orgId == resource.data.orgId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.role in ['admin', 'member']
        && (
          resource.data.deleted == request.resource.data.deleted
          || (request.resource.data.deleted == true
            && request.resource.data.deletedBy == request.auth.uid
            && request.resource.data.status == 'disabled')
        );
      allow delete: if false;
    }

    match /companies/{companyId} {
      allow read: if hasModulePermission(companyId, 'settings', 'view')
        || isOrgAdmin(resource.data.orgId);
      allow create: if isAuthenticated()
        && isOrgAdmin(request.resource.data.orgId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.id == companyId;
      allow update: if hasModulePermission(companyId, 'settings', 'update')
        && companyOrgIdUnchanged()
        && companyCreatedByUnchanged()
        && createdByUnchanged()
        && request.resource.data.updatedBy == request.auth.uid
        && (
          resource.data.deleted == request.resource.data.deleted
          || (request.resource.data.deleted == true
            && request.resource.data.deletedBy == request.auth.uid
            && isOrgAdmin(resource.data.orgId))
        );
      allow delete: if false;
    }

    match /companyRoles/{roleDocId} {
      allow read: if isAuthenticated() && isActiveMember(resource.data.companyId);
      allow create: if canManageCompanyRoles(request.resource.data.companyId);
      allow update: if canManageCompanyRoles(resource.data.companyId) && resource.data.role != 'admin';
      allow delete: if false;
    }

    match /companyMembers/{memberId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        hasModulePermission(resource.data.companyId, 'team', 'view')
      );
      allow create: if isBootstrapAdminMember(memberId)
        || isSelfJoinViaInvite(memberId)
        || (hasModulePermission(request.resource.data.companyId, 'team', 'create')
          && request.resource.data.status == 'active'
          && request.resource.data.role in ['admin', 'manager', 'viewer', 'accountant']);
      allow update: if hasModulePermission(resource.data.companyId, 'team', 'update')
        && resource.data.userId != request.auth.uid
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.role in ['admin', 'manager', 'viewer', 'accountant']
        && (
          resource.data.deleted == request.resource.data.deleted
          || (request.resource.data.deleted == true
            && request.resource.data.deletedBy == request.auth.uid
            && request.resource.data.status == 'disabled'
            && hasModulePermission(resource.data.companyId, 'team', 'delete'))
        );
      allow delete: if false;
    }

    match /companyInvites/{inviteId} {
      allow read: if isAuthenticated() && (
        hasModulePermission(resource.data.companyId, 'team', 'view') || inviteEmailMatchesAuth()
      );
      allow create: if hasModulePermission(request.resource.data.companyId, 'team', 'create')
        && request.resource.data.status == 'pending'
        && request.resource.data.role in ['admin', 'manager', 'viewer', 'accountant'];
      allow update: if hasModulePermission(resource.data.companyId, 'team', 'update')
        || isAcceptingInvite()
        || (hasModulePermission(resource.data.companyId, 'team', 'delete')
          && resource.data.status == 'pending'
          && request.resource.data.status == 'revoked'
          && request.resource.data.deleted == true
          && request.resource.data.deletedBy == request.auth.uid);
      allow delete: if false;
    }

    match /products/{docId} {
      allow read: if canReadModuleDoc('products');
      allow update: if canUpdateModuleDoc('products');
      allow delete: if canDeleteModuleDoc('products');
      allow create: if canCreateModule('products');
    }

    match /sales/{docId} {
      allow read: if canReadModuleDoc('sales');
      allow update: if canUpdateModuleDoc('sales');
      allow delete: if canDeleteModuleDoc('sales');
      allow create: if canCreateModule('sales');
    }

    match /expenses/{docId} {
      allow read: if canReadModuleDoc('expenses');
      allow update: if canUpdateModuleDoc('expenses');
      allow delete: if canDeleteModuleDoc('expenses');
      allow create: if canCreateModule('expenses');
    }

    match /vendors/{docId} {
      allow read: if canReadModuleDoc('vendors');
      allow update: if canUpdateModuleDoc('vendors');
      allow delete: if canDeleteModuleDoc('vendors');
      allow create: if canCreateModule('vendors');
    }

    match /purchases/{docId} {
      allow read: if canReadModuleDoc('purchases');
      allow update: if canUpdateModuleDoc('purchases');
      allow delete: if canDeleteModuleDoc('purchases');
      allow create: if canCreateModule('purchases');
    }

    match /stock/{docId} {
      allow read: if canReadModuleDoc('products');
      allow update: if canUpdateModuleDoc('products');
      allow delete: if canDeleteModuleDoc('products');
      allow create: if canCreateModule('products');
    }

    match /customers/{docId} {
      allow read: if canReadModuleDoc('customers');
      allow update: if canUpdateModuleDoc('customers');
      allow delete: if canDeleteModuleDoc('customers');
      allow create: if canCreateModule('customers');
    }

    match /invoices/{docId} {
      allow read: if canReadModuleDoc('invoices');
      allow update: if canUpdateModuleDoc('invoices');
      allow delete: if canDeleteModuleDoc('invoices');
      allow create: if canCreateModule('invoices');
    }

    match /payments/{docId} {
      allow read: if canReadModuleDoc('payments');
      allow update: if canUpdateModuleDoc('payments');
      allow delete: if canDeleteModuleDoc('payments');
      allow create: if canCreateModule('payments');
    }

    match /auditLogs/{logId} {
      allow create: if isAuthenticated()
        && isActiveMember(request.resource.data.companyId)
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && hasModulePermission(resource.data.companyId, 'team', 'view');
      allow update, delete: if false;
    }

    match /aiChats/{docId} {
      allow read: if canReadModuleDoc('ai_assistant');
      allow update: if canUpdateModuleDoc('ai_assistant');
      allow delete: if false;
      allow create: if canCreateModule('ai_assistant');

      match /messages/{messageId} {
        allow read, delete: if ownsParentAiChat(docId);
        allow create, update: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
