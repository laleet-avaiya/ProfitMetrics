rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isActiveCompanyMember(companyId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/companyMembers/$(companyId + '_' + request.auth.uid))
        && firestore.get(/databases/(default)/documents/companyMembers/$(companyId + '_' + request.auth.uid)).data.status == 'active';
    }

    function attachmentWriteAllowed() {
      return request.resource == null
        || (
          request.resource.size < 10 * 1024 * 1024
          && request.resource.contentType.matches('image/.*|application/pdf')
        );
    }

    match /{orgId}/companies/{companyId}/{allPaths=**} {
      allow read: if isActiveCompanyMember(companyId);
      allow write: if isActiveCompanyMember(companyId) && attachmentWriteAllowed();
    }
  }
}
